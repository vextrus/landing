# apps/landing — environment for the contact form (app/api/contact/route.ts)
# Copy to .env.local for local dev, or set these in the Vercel project (Settings → Environment Variables).

# Notification address for demo requests. Falls back to ceo@vextrus.com if unset.
CONTACT_EMAIL=ceo@vextrus.com

# Optional: POST target for demo-request payloads (Slack Incoming Webhook / CRM / Zapier / Make).
# If unset, the route logs the lead server-side and still returns success — so the form works without it.
CONTACT_WEBHOOK_URL=
